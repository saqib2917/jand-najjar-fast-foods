rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reviews
    // Document ID: reviewId
    // Fields:
    //   - id: string (optional)
    //   - itemId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - rating: number (required, 1-5)
    //   - comment: string (required, 1-500 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: orders
    // Document ID: orderId
    // Fields:
    //   - id: string (optional)
    //   - userId: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "saqi007861@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidReview(data) {
      return data.itemId is string &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() <= 500 &&
             data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /reviews/{reviewId} {
      allow read: if true; // Reviews are public
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
    }
  }
}
